        <!-- Insight -->
        <mxCell id="insight" value="关键洞察：torch.compile + Triton 让 PyTorch 不再强依赖 CUDA 库层，&#xa;开发者用纯 Python 即可生成接近手写 CUDA 的 GPU kernel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#f59e0b;strokeWidth=2;fontSize=13;fontStyle=2;align=center;" vertex="1" parent="1">
