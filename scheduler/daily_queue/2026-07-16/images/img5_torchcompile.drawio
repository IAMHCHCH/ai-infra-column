        <!-- Benefit boxes -->
        <mxCell id="b1" value="✅ 无需手写 CUDA&#xa;Python 即可获得 C++ 级性能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#10B981;strokeWidth=2;fontSize=12;align=center;" vertex="1" parent="1">
